<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.RentalsPage"
             Title="My Rentals">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Outgoing Rental Requests"
                   FontSize="20"
                   FontAttributes="Bold" />

            <Button Text="Load Outgoing Rentals"
                    Command="{Binding LoadOutgoingRentalsCommand}" />

            <CollectionView ItemsSource="{Binding OutgoingRentals}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10"
                                Margin="0,5"
                                Stroke="LightGray">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding Rental.Item.Title}"
                                       FontSize="18"
                                       FontAttributes="Bold" />

                                <Label Text="{Binding Rental.Item.Description}" />

                                <Label Text="{Binding Rental.StartDate, StringFormat='Start Date: {0}'}" />

                                <Label Text="{Binding Rental.EndDate, StringFormat='End Date: {0}'}" />

                                <Label Text="{Binding Rental.Status, StringFormat='Status: {0}'}" />

                                <Label Text="{Binding Rental.TotalPrice, StringFormat='Total Price: £{0:F2}'}" />
                                
                                <HorizontalStackLayout Spacing="10"
                                                       Margin="0,10,0,0">

                                    <Button Text="Mark Returned"
                                            IsVisible="{Binding CanMarkReturned}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkReturnedCommand}"
                                            CommandParameter="{Binding .}" />

                                    <Button Text="Leave Review"
                                            IsVisible="{Binding CanReview}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.LeaveReviewCommand}"
                                            CommandParameter="{Binding .}" />

                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Incoming Rental Requests"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,15,0,0" />

            <Button Text="Load Incoming Rentals"
                    Command="{Binding LoadIncomingRentalsCommand}" />

            <CollectionView ItemsSource="{Binding IncomingRentals}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10"
                                Margin="0,5"
                                Stroke="LightGray">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenIncomingRentalItemCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding Rental.Item.Title}"
                                       FontSize="18"
                                       FontAttributes="Bold" />

                                <Label Text="{Binding Rental.Borrower.FullName, StringFormat='Borrower: {0}'}"
                                       FontAttributes="Italic" />

                                <Label Text="{Binding Rental.StartDate, StringFormat='Start Date: {0}'}" />

                                <Label Text="{Binding Rental.EndDate, StringFormat='End Date: {0}'}" />

                                <Label Text="{Binding Rental.Status, StringFormat='Status: {0}'}" />

                                <Label Text="{Binding Rental.TotalPrice, StringFormat='Total Price: £{0:F2}'}" />

                                <HorizontalStackLayout Spacing="10"
                                                       Margin="0,10,0,0"
                                                       IsVisible="{Binding CanApproveOrReject}">

                                    <Button Text="Approve"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ApproveRentalCommand}"
                                            CommandParameter="{Binding .}" />

                                    <Button Text="Reject"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RejectRentalCommand}"
                                            CommandParameter="{Binding .}" />

                                </HorizontalStackLayout>

                                <Button Text="Mark Out For Rent"
                                        IsVisible="{Binding CanMarkOutForRent}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkOutForRentCommand}"
                                        CommandParameter="{Binding .}" />

                                <Button Text="Complete Rental"
                                        IsVisible="{Binding CanComplete}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CompleteRentalCommand}"
                                        CommandParameter="{Binding .}" />

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="{Binding StatusMessage}"
                   TextColor="Green" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>