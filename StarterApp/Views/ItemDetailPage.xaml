<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.ItemDetailPage"
             Title="Item Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

              <!-- Label = A text display -->
              <Label Text="Item Details"
                   FontSize="24"
                   FontAttributes="Bold" />

              <Label Text="{Binding Item.Title}"
                   FontSize="20"
                   FontAttributes="Bold" />

              <Label Text="{Binding Item.Description}" />

              <Label Text="{Binding Item.Category}" />

              <Label Text="{Binding Item.DailyRate, StringFormat='£{0:F2} per day'}" /> <!-- Formats the price as pounds with 2 decimal places -->

              <Label Text="{Binding Item.LocationName}" />

              <Button Text="Request Rental"
                     Clicked="OnRequestRentalClicked" />

              <Button Text="Edit Item"
                     Clicked="OnEditItemClicked" />

              <Label Text="{Binding StatusMessage}"
                     TextColor="Red" />

              <BoxView HeightRequest="1"
                       BackgroundColor="LightGray"
                       Margin="0,10,0,10" />

              <Label Text="Reviews"
                     FontSize="22"
                     FontAttributes="Bold" />

              <Button Text="Load Reviews"
                      Command="{Binding LoadReviewsCommand}" />

              <CollectionView ItemsSource="{Binding Reviews}">
                  <CollectionView.ItemTemplate>
                      <DataTemplate>
                          <Border Padding="10"
                                  Margin="0,5"
                                  Stroke="LightGray">
                              <Border.StrokeShape>
                                  <RoundRectangle CornerRadius="8" />
                              </Border.StrokeShape>

                              <VerticalStackLayout Spacing="5">
                                  <Label Text="{Binding Rating, StringFormat='Rating: {0}/5'}"
                                         FontAttributes="Bold" />

                                  <Label Text="{Binding Comment}" />

                                  <Label Text="{Binding Reviewer.FullName, StringFormat='Reviewer: {0}'}"
                                         FontAttributes="Italic" />

                                  <Label Text="{Binding CreatedAt, StringFormat='Created: {0}'}"
                                         FontSize="12" />
                              </VerticalStackLayout>
                          </Border>
                      </DataTemplate>
                  </CollectionView.ItemTemplate>
              </CollectionView>

              <Label Text="{Binding ReviewStatusMessage}"
                     TextColor="Green" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>