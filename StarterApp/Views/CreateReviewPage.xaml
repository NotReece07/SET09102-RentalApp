<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.CreateReviewPage"
             Title="Create Review">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Create Review"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="Rental and item details are filled in automatically from the selected rental."
                   FontSize="14" />

            <Label Text="{Binding RentalId, StringFormat='Rental ID: {0}'}" />

            <Label Text="{Binding ItemId, StringFormat='Item ID: {0}'}" />

            <Entry Placeholder="Rating (1-5)"
                   Keyboard="Numeric"
                   Text="{Binding Rating}" />

            <Editor Placeholder="Write your review comment here"
                    AutoSize="TextChanges"
                    HeightRequest="100"
                    Text="{Binding Comment}" />

            <Button Text="Submit Review"
                    Command="{Binding CreateReviewCommand}" />

            <Label Text="{Binding StatusMessage}"
                   TextColor="Green" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>