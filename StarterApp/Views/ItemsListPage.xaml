<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.ItemsListPage"
             Title="Items">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Button Text="Load Items"
                Command="{Binding LoadItemsCommand}" />

        <CollectionView ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10"
                           Margin="0,5"
                           BorderColor="LightGray"
                           BackgroundColor="White">
                           <!-- Below code makes the entire card responsible for handling the tap directly -->
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnItemTapped" />
                        </Frame.GestureRecognizers>

                        <VerticalStackLayout Spacing="5"
                                             InputTransparent="True">
                            <Label Text="{Binding Title}"
                                   FontSize="18"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding Description}" />
                            <Label Text="{Binding Category}" />
                            <Label Text="{Binding DailyRate, StringFormat='£{0:F2} per day'}" />
                            <Label Text="{Binding LocationName}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>