<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.TempPage"
             xmlns:vm="clr-namespace:StarterApp.ViewModels"
             Title="{Binding Title}">

    <ContentPage.BindingContext>
        <vm:TempViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label 
                Text="{Binding Message}"
                FontSize="24"
                HorizontalOptions="Center" />

            <Button Text="Open Items List"
                    Clicked="OnOpenItemsListClicked" />

            <Button Text="Open Create Item"
                    Clicked="OnOpenCreateItemClicked" />

            <Button Text="Open Item Detail"
                    Clicked="OnOpenItemDetailClicked" />

            <Button Text="Open Edit Item"
                    Clicked="OnOpenEditItemClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>