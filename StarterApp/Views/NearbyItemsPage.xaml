<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.NearbyItemsPage"
             Title="Nearby Items">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Find Nearby Items"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="Search for items close to your current location." />

            <Entry Placeholder="Radius in km"
                   Keyboard="Numeric"
                   Text="{Binding RadiusKm}" />

            <Button Text="Find Near Me"
                    Command="{Binding FindNearbyItemsCommand}" />

            <Label Text="{Binding StatusMessage}"
                   TextColor="Green" />

            <CollectionView ItemsSource="{Binding NearbyItems}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="10"
                            Margin="0,5"
                            BorderColor="LightGray"
                            BackgroundColor="White">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenItemCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <VerticalStackLayout Spacing="5"
                                                InputTransparent="True">
                                <Label Text="{Binding Title}"
                                    FontSize="18"
                                    FontAttributes="Bold" />
                                <Label Text="{Binding Description}" />
                                <Label Text="{Binding Category}" />
                                <Label Text="{Binding DailyRate, StringFormat='£{0:F2} per day'}" />
                                <Label Text="{Binding LocationName}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>